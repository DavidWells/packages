{
  "name": "@davidwells/md-utils",
  "version": "0.0.59",
  "description": "Simple MD utils",
  "main": "src/index.js",
  "module": "src/index.mjs",
  "sideEffects": false,
  "author": "David Wells",
  "license": "MIT",
  "exports": {
    ".": {
      "import": "./src/index.mjs",
      "require": "./src/index.js"
    },
    "./parse": {
      "import": "./src/parse.mjs",
      "require": "./src/parse.js"
    },
    "./parse/frontmatter": {
      "import": "./src/parse-with-frontmatter.mjs",
      "require": "./src/parse-with-frontmatter.js"
    },
    "./parse/toc": {
      "import": "./src/parse-with-toc.mjs",
      "require": "./src/parse-with-toc.js"
    },
    "./parse/code-blocks": {
      "import": "./src/parse-with-code-blocks.mjs",
      "require": "./src/parse-with-code-blocks.js"
    },
    "./parse/links": {
      "import": "./src/parse-with-links.mjs",
      "require": "./src/parse-with-links.js"
    },
    "./frontmatter": {
      "import": "./src/frontmatter.mjs",
      "require": "./src/frontmatter.js"
    },
    "./dedent": {
      "import": "./src/utils/dedent.mjs",
      "require": "./src/utils/dedent.js"
    },
    "./slugger": {
      "import": "./src/utils/slugger.mjs",
      "require": "./src/utils/slugger.js"
    },
    "./toc": {
      "import": "./src/toc/index.mjs",
      "require": "./src/toc/index.js"
    },
    "./toc/normalize": {
      "import": "./src/toc/normalize.mjs",
      "require": "./src/toc/normalize.js"
    },
    "./find-code-blocks": "./src/find-code-blocks.js",
    "./find-headings": "./src/find-headings.js",
    "./find-frontmatter": "./src/find-frontmatter.js",
    "./find-images": "./src/find-images.js",
    "./find-links": "./src/find-links.js",
    "./find-unmatched-html-tags": "./src/find-unmatched-html-tags.js",
    "./find-footnotes": "./src/find-footnotes.js",
    "./find-date": "./src/find-date.js",
    "./find-html-tags": "./src/find-html-tags.js",
    "./string-utils": "./src/string-utils.js",
    "./extract-section": "./src/extract-section.js"
  },
  "scripts": {
    "test": "uvu src '.test.([mc]js|[jt]sx?)$'",
    "release:patch": "npm version patch && npm publish",
    "release:minor": "npm version minor && npm publish",
    "release:major": "npm version major && npm publish"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/DavidWells/components/packages/util-md"
  },
  "dependencies": {
    "gray-matter": "^4.0.3",
    "micro-mdx-parser": "^1.1.1",
    "oparser": "^3.0.1"
  },
  "devDependencies": {
    "uvu": "^0.5.1"
  }
}
